        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ {\n  \"contents\": [\n    {\n      \"parts\": [\n        {\n          \"text\": \"Ekstrak instagram post ini menjadi JSON murni dengan field: nama instagram, judul konten maksimal dua paragraf pertama di caption.\\n\\nData mentah: \" + JSON.stringify($json.markdown || $json.raw_data?.markdown || $json)\n        }\n      ]\n    }\n  ]\n} }}",
        "options": {
          "timeout": 30000
        }
      },
      "id": "49e970b3-b6af-47cf-b318-563936e5ec5f",
