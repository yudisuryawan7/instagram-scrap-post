              "id": "parse-ai-json",
              "name": "parsed",
              "type": "object",
              "value": "={{ (() => { try { const raw = $json.candidates?.[0]?.content?.parts?.[0]?.text || '{}'; const match = raw.match(/\\{[\\s\\S]*\\}/); return match ? JSON.parse(match[0]) : {}; } catch(e) { return { error: e.message }; } })() }}"
            },
            {
              "id": "pass-job-url",
              "name": "job_url",
              "type": "string",
              "value": "={{ $('Extract & Detect Platform').item.json.job_url }}"
            },
